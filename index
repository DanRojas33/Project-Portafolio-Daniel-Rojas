<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daniel Rojas Rojas — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy-950:#070f1f;
    --navy-900:#0b1f3a;
    --navy-800:#12294d;
    --navy-700:#1c3a66;
    --line:rgba(255,255,255,0.10);
    --line-strong:rgba(255,255,255,0.20);
    --bone:#f7f6f3;
    --bone-dim:#cbd2dd;
    --amber:#d4a24c;
    --amber-soft:rgba(212,162,76,0.16);
    --green:#3fa66b;
    --green-soft:rgba(63,166,107,0.16);
    --red:#c44536;
    --red-soft:rgba(196,69,54,0.16);
    --display:'Space Grotesk',sans-serif;
    --mono:'JetBrains Mono',monospace;
    --body:'Inter',sans-serif;
  }

  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--navy-950);
    color:var(--bone);
    font-family:var(--body);
    overflow-x:hidden;
    background-image:
      radial-gradient(circle at 15% 0%, rgba(28,58,102,0.45), transparent 55%),
      radial-gradient(circle at 85% 15%, rgba(212,162,76,0.07), transparent 45%);
  }

  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important; scroll-behavior:auto !important;}
  }

  a{color:inherit;}
  ::selection{background:var(--amber); color:var(--navy-950);}

  /* ---------- utility ---------- */
  .wrap{max-width:1180px; margin:0 auto; padding:0 32px;}
  .eyebrow{
    font-family:var(--mono); font-size:11px; letter-spacing:0.18em; text-transform:uppercase;
    color:var(--amber); display:flex; align-items:center; gap:10px; font-weight:500;
  }
  .eyebrow::before{content:""; width:6px; height:6px; border-radius:50%; background:var(--amber); box-shadow:0 0 0 3px var(--amber-soft); flex:none;}
  .section-title{font-family:var(--display); font-weight:600; font-size:clamp(28px,4vw,42px); letter-spacing:-0.01em; line-height:1.1;}
  .section-pad{padding:96px 0;}
  button:focus-visible, a:focus-visible, [tabindex]:focus-visible{outline:2px solid var(--amber); border-radius:4px;}

  /* ---------- nav ---------- */
  .topbar{
    position:fixed; top:0; left:0; right:0; z-index:50;
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 32px; backdrop-filter:blur(14px);
    background:rgba(7,15,31,0.72); border-bottom:1px solid var(--line);
  }
  .brand{display:flex; align-items:center; gap:10px; font-family:var(--display); font-weight:600; font-size:15px; letter-spacing:0.01em;}
  .brand-mark{width:30px; height:30px; border-radius:7px; background:linear-gradient(135deg,var(--amber),#9c7530); display:flex; align-items:center; justify-content:center; font-family:var(--mono); font-weight:700; color:var(--navy-950); font-size:13px;}
  .navlinks{display:flex; gap:28px; font-size:13px; font-weight:500; color:var(--bone-dim);}
  .navlinks a{text-decoration:none; transition:color .2s; padding:4px 0;}
  .navlinks a:hover{color:var(--bone);}
  .nav-right{display:flex; align-items:center; gap:16px;}
  .nav-status{display:flex; align-items:center; gap:8px; font-family:var(--mono); font-size:11px; color:var(--green); letter-spacing:0.05em;}
  .nav-status .dot{width:6px; height:6px; border-radius:50%; background:var(--green); box-shadow:0 0 0 3px var(--green-soft); animation:pulse 2.4s infinite;}
  @keyframes pulse{0%,100%{opacity:1;} 50%{opacity:.45;}}
  @media(max-width:760px){.navlinks{display:none;}}

  /* ---------- LANGUAGE TOGGLE BUTTON ---------- */
  .lang-toggle{
    font-family:var(--mono); font-size:11.5px; font-weight:700; letter-spacing:0.06em;
    padding:7px 14px; border-radius:20px; border:1px solid var(--amber);
    background:var(--amber-soft); color:var(--amber); cursor:pointer;
    display:flex; align-items:center; gap:7px; transition:all .2s; white-space:nowrap;
    flex-shrink: 0;
  }
  .lang-toggle:hover{background:var(--amber); color:var(--navy-950);}
  .lang-toggle .globe-icon{font-size:13px; line-height:1;}

  /* ---------- hero ---------- */
  .hero{
    min-height:100vh; display:flex; flex-direction:column; justify-content:center;
    padding:140px 0 80px; position:relative;
  }
  .hero-grid{display:grid; grid-template-columns:1.25fr 0.9fr; gap:56px; align-items:end;}
  @media(max-width:900px){.hero-grid{grid-template-columns:1fr;}}
  .hero-name{
    font-family:var(--display); font-weight:700; letter-spacing:-0.02em;
    font-size:clamp(44px,7vw,84px); line-height:0.98; margin-top:18px;
  }
  .hero-name .accent{color:var(--amber);}
  .hero-role{
    margin-top:18px; font-size:17px; color:var(--bone-dim); max-width:560px; line-height:1.6;
  }
  .hero-role b{color:var(--bone); font-weight:600;}
  .hero-cta{display:flex; gap:14px; margin-top:34px; flex-wrap:wrap;}
  .btn{
    font-family:var(--mono); font-size:12.5px; letter-spacing:0.04em; font-weight:600;
    padding:13px 22px; border-radius:8px; border:1px solid var(--line-strong); cursor:pointer;
    text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all .2s;
    background:transparent; color:var(--bone);
  }
  .btn-primary{background:var(--amber); color:var(--navy-950); border-color:var(--amber);}
  .btn-primary:hover{background:#e3b25e; transform:translateY(-1px);}
  .btn:not(.btn-primary):hover{border-color:var(--amber); color:var(--amber);}

  .readout{
    border:1px solid var(--line); border-radius:14px; background:rgba(18,41,77,0.45);
    padding:22px; font-family:var(--mono);
  }
  .readout-head{display:flex; justify-content:space-between; align-items:center; font-size:11px; color:var(--bone-dim); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:16px; padding-bottom:14px; border-bottom:1px solid var(--line);}
  .readout-row{display:flex; justify-content:space-between; align-items:baseline; padding:10px 0; border-bottom:1px dashed var(--line);}
  .readout-row:last-child{border-bottom:none;}
  .readout-label{font-size:12px; color:var(--bone-dim);}
  .readout-val{font-size:20px; font-weight:700; color:var(--bone);}
  .readout-val.green{color:var(--green);}
  .readout-val.amber{color:var(--amber);}

  .scrollcue{position:absolute; bottom:28px; left:32px; display:flex; align-items:center; gap:10px; font-family:var(--mono); font-size:10.5px; color:var(--bone-dim); letter-spacing:0.12em;}
  .scrollcue .line{width:1px; height:30px; background:linear-gradient(var(--amber),transparent); animation:slide 1.8s infinite;}
  @keyframes slide{0%{transform:translateY(-6px); opacity:0;} 40%{opacity:1;} 100%{transform:translateY(10px); opacity:0;}}

  /* ---------- kpi strip ---------- */
  .kpi-strip{border-top:1px solid var(--line); border-bottom:1px solid var(--line); background:rgba(11,31,58,0.4);}
  .kpi-row{display:grid; grid-template-columns:repeat(4,1fr);}
  @media(max-width:760px){.kpi-row{grid-template-columns:repeat(2,1fr);}}
  .kpi-cell{padding:34px 28px; border-right:1px solid var(--line); position:relative;}
  .kpi-cell:last-child{border-right:none;}
  .kpi-num{font-family:var(--mono); font-weight:700; font-size:clamp(26px,3.4vw,38px); color:var(--amber); display:flex; align-items:baseline; gap:2px;}
  .kpi-label{margin-top:8px; font-size:12.5px; color:var(--bone-dim); line-height:1.5;}

  /* ---------- section frame ---------- */
  .frame-head{display:flex; justify-content:space-between; align-items:flex-end; gap:24px; margin-bottom:48px; flex-wrap:wrap;}
  .frame-head p{color:var(--bone-dim); font-size:14.5px; max-width:420px; line-height:1.6; margin-top:14px;}

  /* ---------- schema map ---------- */
  .schema-shell{
    border:1px solid var(--line); border-radius:18px; background:rgba(11,21,41,0.55);
    padding:8px; position:relative; overflow:hidden;
  }
  .schema-shell::before{
    content:""; position:absolute; inset:0; pointer-events:none; opacity:.5;
    background-image:linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size:42px 42px; mask-image:radial-gradient(circle at 50% 50%, black 0%, transparent 75%);
  }
  .schema-canvas{position:relative; width:100%;}
  .schema-svg{width:100%; height:auto; display:block;}
  .node-card{cursor:pointer; transition:transform .25s ease;}
  .node-card:hover{transform:translateY(-3px);}
  .node-card .node-bg{transition:stroke .2s, filter .2s;}
  .node-card:hover .node-bg{stroke:var(--amber); filter:drop-shadow(0 0 10px rgba(212,162,76,0.35));}
  .flow-path{stroke-dasharray:6 6; animation:dash 2.4s linear infinite;}
  @keyframes dash{to{stroke-dashoffset:-120;}}
  .pulse-dot{animation:pulse 2.2s infinite;}

  .schema-legend{display:flex; gap:22px; flex-wrap:wrap; padding:18px 18px 10px; font-family:var(--mono); font-size:11px; color:var(--bone-dim);}
  .legend-item{display:flex; align-items:center; gap:8px;}
  .legend-dot{width:8px; height:8px; border-radius:50%;}

  .node-detail{
    margin-top:18px; border:1px solid var(--line); border-radius:14px; padding:26px 28px;
    background:rgba(18,41,77,0.4); display:none;
  }
  .node-detail.active{display:block; animation:fadein .3s ease;}
  @keyframes fadein{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}
  .node-detail-head{display:flex; justify-content:space-between; align-items:flex-start; gap:18px; flex-wrap:wrap; margin-bottom:16px;}
  .node-detail-title{font-family:var(--display); font-weight:600; font-size:22px;}
  .node-detail-meta{font-family:var(--mono); font-size:11.5px; color:var(--amber); letter-spacing:0.06em; margin-top:6px;}
  .node-detail-badge{font-family:var(--mono); font-size:11px; padding:6px 12px; border-radius:20px; background:var(--green-soft); color:var(--green); white-space:nowrap;}
  .node-detail-results{display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-top:18px;}
  @media(max-width:700px){.node-detail-results{grid-template-columns:1fr;}}
  .ndr-item{border:1px solid var(--line); border-radius:10px; padding:14px 16px; font-size:13px; color:var(--bone-dim); line-height:1.5; display:flex; gap:10px; align-items:flex-start;}
  .ndr-item::before{content:"›"; color:var(--amber); font-weight:700; flex:none;}

  /* ---------- track records ---------- */
  .tracks{display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:20px; max-width:800px;}
  @media(max-width:760px){.tracks{grid-template-columns:1fr;}}
  .track{
    border:1px solid var(--line); border-radius:14px; padding:26px; cursor:pointer;
    background:rgba(18,41,77,0.25); transition:border-color .25s, background .25s, transform .25s;
    position:relative; overflow:hidden;
  }
  .track:hover{border-color:var(--line-strong); background:rgba(18,41,77,0.5); transform:translateY(-4px);}
  .track-icon{width:42px; height:42px; border-radius:10px; background:var(--amber-soft); display:flex; align-items:center; justify-content:center; margin-bottom:18px;}
  .track h3{font-family:var(--display); font-size:18px; font-weight:600; margin-bottom:6px;}
  .track .track-meta{font-family:var(--mono); font-size:11px; color:var(--bone-dim); letter-spacing:0.04em; margin-bottom:14px;}
  .track ul{list-style:none; display:flex; flex-direction:column; gap:9px;}
  .track li{font-size:13.5px; color:var(--bone-dim); display:flex; gap:9px; line-height:1.5;}
  .track li::before{content:"✓"; color:var(--green); font-weight:700; flex:none;}
  .track .bar-row{margin-top:18px; display:flex; align-items:center; gap:10px;}
  .bar-track{flex:1; height:6px; border-radius:4px; background:rgba(255,255,255,0.08); overflow:hidden;}
  .bar-fill{height:100%; border-radius:4px; background:linear-gradient(90deg,var(--amber),#e3b25e); width:0%; transition:width 1.2s cubic-bezier(.2,.8,.2,1);}
  .bar-pct{font-family:var(--mono); font-size:12px; color:var(--amber); font-weight:700; min-width:38px; text-align:right;}

  /* ---------- competencies ---------- */
  .comp-grid{display:flex; flex-wrap:wrap; gap:10px;}
  .chip{
    font-family:var(--mono); font-size:12.5px; padding:9px 16px; border-radius:20px;
    border:1px solid var(--line-strong); color:var(--bone-dim); cursor:default; transition:all .2s; user-select:none;
  }
  .chip:hover{border-color:var(--amber); color:var(--amber); background:var(--amber-soft);}
  .chip.tier-core{border-color:rgba(212,162,76,0.4); color:var(--amber);}

  .tools-grid{display:grid; grid-template-columns:repeat(auto-fit, minmax(230px,1fr)); gap:24px; margin-top:8px;}
  .tool-cat-title{font-family:var(--mono); font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:var(--bone-dim); margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid var(--line);}
  .tool-cat .comp-grid{gap:8px;}
  .tool-cat .chip{font-size:11.5px; padding:7px 13px;}

  /* ---------- education ---------- */
  .edu-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:32px;}
  @media(max-width:900px){.edu-grid{grid-template-columns:1fr;}}
  .edu-col-title{display:flex; align-items:center; gap:10px; font-family:var(--display); font-weight:600; font-size:16px; margin-bottom:18px; padding-bottom:14px; border-bottom:1px solid var(--line);}
  .dot-amber{width:8px; height:8px; border-radius:50%; background:var(--amber); flex:none;}
  .dot-green{width:8px; height:8px; border-radius:50%; background:var(--green); flex:none;}
  .edu-item{padding:13px 0; border-bottom:1px dashed var(--line);}
  .edu-item:last-of-type{border-bottom:none;}
  .edu-item-title{font-size:13.5px; color:var(--bone); line-height:1.45; font-weight:500;}
  .edu-item-meta{font-family:var(--mono); font-size:11px; color:var(--amber); margin-top:5px; letter-spacing:0.02em;}
  .lang-row{display:flex; align-items:center; gap:12px; margin-bottom:16px;}
  .lang-label{font-size:13px; color:var(--bone-dim); min-width:55px;}
  .lang-pct{font-family:var(--mono); font-size:11.5px; color:var(--amber); min-width:48px; text-align:right;}
  .lang-bar{width:0%;}

  /* ---------- footer / contact ---------- */
  .cta-band{border-top:1px solid var(--line); padding:90px 0; text-align:center; position:relative;}
  .cta-band h2{font-family:var(--display); font-weight:600; font-size:clamp(28px,4vw,40px); margin-bottom:18px;}
  .cta-band p{color:var(--bone-dim); max-width:480px; margin:0 auto 32px; font-size:15px; line-height:1.6;}
  footer{padding:28px 0; border-top:1px solid var(--line); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;}
  footer .fmono{font-family:var(--mono); font-size:11.5px; color:var(--bone-dim); letter-spacing:0.04em;}

  .reveal{opacity:0; transform:translateY(18px); transition:opacity .6s ease, transform .6s ease;}
  .reveal.in{opacity:1; transform:translateY(0);}

  /* ---------- i18n visibility ---------- */
  [data-lang]{display:none !important;}
  .lang-es [data-lang="es"]{display:revert !important;}
  .lang-en [data-lang="en"]{display:revert !important;}
  .lang-es ul[data-lang="es"],
  .lang-en ul[data-lang="en"]{display:flex !important; flex-direction:column; gap:9px;}
  .lang-es span[data-lang="es"],
  .lang-en span[data-lang="en"]{display:inline !important;}
  .lang-es div[data-lang="es"],
  .lang-en div[data-lang="en"]{display:block !important;}
  .lang-es .schema-canvas[data-lang="es"],
  .lang-en .schema-canvas[data-lang="en"]{display:block !important;}
  .lang-es .comp-grid[data-lang="es"],
  .lang-en .comp-grid[data-lang="en"]{display:flex !important; flex-wrap:wrap; gap:10px;}
  .lang-es .tool-cat-title[data-lang="es"],
  .lang-en .tool-cat-title[data-lang="en"]{display:block !important;}

  /* transition suave al cambiar idioma */
  body{transition:opacity .15s ease;}
  body.switching{opacity:0;}
</style>
</head>
