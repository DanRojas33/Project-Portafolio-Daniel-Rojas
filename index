<script>
  // ---- LANGUAGE TOGGLE ----
  const body = document.getElementById('body-root');
  const htmlRoot = document.getElementById('html-root');
  const btn = document.getElementById('lang-btn');
  let currentLang = 'en';

  btn.addEventListener('click', () => {
    body.classList.add('switching');
    setTimeout(() => {
      currentLang = currentLang === 'es' ? 'en' : 'es';
      body.className = body.className.replace(/lang-(es|en)/, 'lang-' + currentLang);
      htmlRoot.lang = currentLang;
      // reset detail panels for new lang
      showDetail('governance');
      body.classList.remove('switching');
    }, 150);
  });

  // ---- KPI COUNTERS ----
  const animateCounter = (el) => {
    const target = parseInt(el.dataset.count, 10);
    const suffix = el.dataset.suffix || '';
    const dur = 1400;
    const start = performance.now();
    const step = (now) => {
      const p = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  // ---- INTERSECTION OBSERVER ----
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in');
        if (entry.target.classList.contains('kpi-num') && !entry.target.dataset.done) {
          entry.target.dataset.done = "1";
          animateCounter(entry.target);
        }
        if (entry.target.classList.contains('track')) {
          const fill = entry.target.querySelector('.bar-fill');
          const pct = entry.target.dataset.bar;
          requestAnimationFrame(() => { fill.style.width = (pct > 100 ? 100 : pct) + '%'; });
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.25 });

  document.querySelectorAll('.reveal, .kpi-num, .track').forEach(el => observer.observe(el));

  // ---- LANGUAGE BARS ----
  const langSection = document.getElementById('educacion');
  if (langSection) {
    const langObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          document.querySelectorAll('.lang-bar').forEach(bar => {
            requestAnimationFrame(() => { bar.style.width = bar.dataset.pct + '%'; });
          });
          langObserver.disconnect();
        }
      });
    }, { threshold: 0.2 });
    langObserver.observe(langSection);
  }

  // ---- SCHEMA NODE CLICK ----
  function showDetail(key) {
    ['es', 'en'].forEach(lang => {
      document.querySelectorAll('.node-detail').forEach(d => {
        d.classList.toggle('active', d.id === 'detail-' + key + '-' + lang);
      });
    });
  }

  document.querySelectorAll('.node-card').forEach(node => {
    const key = node.dataset.node;
    node.addEventListener('click', () => showDetail(key));
    node.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); showDetail(key); }
    });
  });

  setTimeout(() => showDetail('governance'), 400);
</script>

